{
  "name": "ats-pipeline-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Express API for the lightweight ATS pipeline tool",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node scripts/migrate.js",
    "test": "node --test ./test/app.test.js ./test/integration.test.js",
    "test:smoke": "node --test ./test/app.test.js",
    "test:integration": "node --test ./test/integration.test.js",
    "test:all": "npm run test:smoke && npm run test:integration"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0"
  }
}
